# ─── Supabase (database order/pembayaran) ──────────────────────────────────
# Dapatkan di: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # RAHASIA, server-only. Jangan diekspos ke browser.

# ─── Midtrans (payment gateway) ─────────────────────────────────────────────
# Dapatkan di: Midtrans Dashboard → Settings → Access Keys
# Pakai key SANDBOX dulu untuk uji coba.
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxx          # RAHASIA, server-only
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxx

# false = Sandbox (uji coba), true = Produksi (uang asli)
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Catatan:
# - Variabel berawalan NEXT_PUBLIC_ boleh tampil di browser (Client Key, URL).
# - SUPABASE_SERVICE_ROLE_KEY & MIDTRANS_SERVER_KEY HARUS rahasia (server-only).
# - Set variabel yang sama di Vercel → Project → Settings → Environment Variables.
